Set<String> seedNames = new Set<String>();
for (Part_Catalog__c part : seedParts) {
    seedNames.add(part.Name);
}

Map<String, Part_Catalog__c> existingByName = new Map<String, Part_Catalog__c>();
for (Part_Catalog__c existingPart : [
    SELECT Id, Name
    FROM Part_Catalog__c
    WHERE Name IN :seedNames
]) {
    existingByName.put(existingPart.Name, existingPart);
}

List<Part_Catalog__c> partsToInsert = new List<Part_Catalog__c>();
List<Part_Catalog__c> partsToUpdate = new List<Part_Catalog__c>();

for (Part_Catalog__c part : seedParts) {
    if (existingByName.containsKey(part.Name)) {
        part.Id = existingByName.get(part.Name).Id;
        partsToUpdate.add(part);
    } else {
        partsToInsert.add(part);
    }
}

if (!partsToInsert.isEmpty()) {
    insert partsToInsert;
}

if (!partsToUpdate.isEmpty()) {
    update partsToUpdate;
}

System.debug('PartCatalogSeed_v3 complete.');
System.debug('Inserted Part Catalog records: ' + partsToInsert.size());
System.debug('Updated Part Catalog records: ' + partsToUpdate.size());
