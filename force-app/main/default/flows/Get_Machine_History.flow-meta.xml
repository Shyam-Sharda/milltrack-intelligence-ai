    <decisions>
        <name>Was_Machine_Found</name>
        <label>Was Machine Found</label>
        <locationX>319</locationX>
        <locationY>244</locationY>
        <defaultConnector>
            <targetReference>Machine_Not_Found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Machine Not Found</defaultConnectorLabel>
        <rules>
            <name>Machine_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Machine.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>InitializeHistory_Variables</targetReference>
            </connector>
            <label>Machine Found</label>
        </rules>
    </decisions>
    <description>Finds a machine by serial number and returns its Asset, related Cases, Work Orders, Maintenance Logs, and parts history for use by the MillTrack Technician Agent.</description>
    <environments>Default</environments>
    <interviewLabel>Get Machine History {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Get Machine History Updated</label>
    <loops>
        <name>Loop_Cases</name>
        <label>Loop Cases</label>
        <locationX>646</locationX>
        <locationY>431</locationY>
        <collectionReference>Get_Related_Machine_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Case_Text</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Work_Orders</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Maintenance_Logs</name>
        <label>Loop Maintenance Logs</label>
        <locationX>1235</locationX>
        <locationY>430</locationY>
        <collectionReference>Get_Maintenance_Logs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Maintenance_Log_Text</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Work_Order_Parts</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Work_Order_Parts</name>
        <label>Loop Work Order Parts</label>
