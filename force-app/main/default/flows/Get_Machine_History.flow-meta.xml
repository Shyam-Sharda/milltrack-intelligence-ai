    <textTemplates>
        <name>machineSummary</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Machine Found

Name: {!Get_Machine.Name}

Serial Number: {!Get_Machine.Serial_Number__c}

Status: {!Get_Machine.Machine_Status__c}</text>
    </textTemplates>
    <textTemplates>
        <name>MaintenanceLogLine</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Maintenance Logs

Maintenance {!Loop_Maintenance_Logs.Name}

Service: {!Loop_Maintenance_Logs.Maintenance_Type__c}

Summary: {!Loop_Maintenance_Logs.Summary__c}

Notes: {!Loop_Maintenance_Logs.Technician_Notes__c}</text>
    </textTemplates>
    <textTemplates>
        <name>PartLine</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Parts Used

Part: {!Loop_Work_Order_Parts.Name}

Qty: {!Loop_Work_Order_Parts.Quantity_Needed__c}</text>
    </textTemplates>
    <textTemplates>
        <name>WorkOrderLine</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Work Orders

Work Order {!Loop_Work_Orders.WorkOrderNumber}

Subject: {!Loop_Work_Orders.Subject}

Status: {!Loop_Work_Orders.Status}

Recommended Solution: {!Loop_Work_Orders.Recommended_Solution__c}

Technician Notes: {!Loop_Work_Orders.Technician_Notes__c}</text>
    </textTemplates>
    <variables>
        <name>caseSummaryText</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>inputCurrentCaseId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>inputCurrentWorkOrderId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Serial number of the dental milling machine the technician is asking about.</description>
