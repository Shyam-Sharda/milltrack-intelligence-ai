        <text>No previous work orders found.</text>
    </textTemplates>
    <textTemplates>
        <name>MachineFoundMessage</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Machine history retrieved successfully.</text>
    </textTemplates>
    <textTemplates>
        <name>MachineNotFoundMessage</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>No machine was found for the provided serial number.</text>
    </textTemplates>
    <textTemplates>
        <name>machineServiceHistory</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Previous Service History



Cases

{!caseSummaryText}



Work Orders

{!workOrderSummaryText}



Maintenance Logs

{!maintenanceLogSummaryText}



Parts Used

{!partSummaryText}</text>
